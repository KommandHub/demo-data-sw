{
    "name": "kommandhub/demo-data-sw",
    "description": "",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Kommandhub Limited",
            "email": "info@kommandhub.com"
        }
    ],
    "require": {
        "shopware/core": "~6.7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "shopware/dev-tools": "^1.5",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "rregeer/phpunit-coverage-check": "^0.3.1"
    },
    "autoload": {
        "psr-4": {
            "Kommandhub\\DemoDataSW\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kommandhub\\DemoDataSW\\Tests\\": "tests/"
        }
    },
    "extra": {
        "shopware-plugin-class": "Kommandhub\\DemoDataSW\\KommandhubDemoDataSW",
        "label": {
            "de-DE": "Shopware Demo Daten",
            "en-GB": "Shopware Demo Data",
            "fr-FR": "Données de démonstration Shopware"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
